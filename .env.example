# Application
PORT=4001
NODE_ENV=development

# Database (local)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=bao_gia

# Database (cloud - overrides DB_HOST/PORT/... when set)
# DATABASE_URL=postgresql://user:pass@host.neon.tech/bao_gia?sslmode=require

# CORS (comma-separated origins, default: http://localhost:4000)
# CORS_ORIGIN=http://localhost:4000,https://your-app.vercel.app

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# Anthropic AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# n8n Integration
# Secret for n8n -> backend API calls (X-Service-Key header)
# Generate: openssl rand -hex 32
N8N_SERVICE_KEY=generate_random_key_here
# Secret for n8n -> backend webhook callbacks (X-Webhook-Secret header)
# Generate: openssl rand -hex 32
N8N_WEBHOOK_SECRET=generate_random_key_here
# n8n base URL (for backend to trigger n8n workflows)
N8N_BASE_URL=http://localhost:5679

# SMTP (email sending for quotations)
# Used by POST /quotations/:id/send-email
# If not set, the endpoint returns 400 Bad Request
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@baogia.vn

# Sentry (error tracking)
# DSN from Sentry project settings
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Auth token for source map uploads (from sentry.io/settings/auth-tokens/)
SENTRY_AUTH_TOKEN=
