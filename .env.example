# Application
PORT=4001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=bao_gia

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# Anthropic AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# n8n Integration
# Secret for n8n -> backend API calls (X-Service-Key header)
# Generate: openssl rand -hex 32
N8N_SERVICE_KEY=generate_random_key_here
# Secret for n8n -> backend webhook callbacks (X-Webhook-Secret header)
# Generate: openssl rand -hex 32
N8N_WEBHOOK_SECRET=generate_random_key_here
# n8n base URL (for backend to trigger n8n workflows)
N8N_BASE_URL=http://localhost:5679
